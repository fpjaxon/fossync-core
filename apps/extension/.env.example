# AMO API credentials for unlisted signing.
# Get them at https://addons.mozilla.org/developers/addon/api/key/
# Export these (or copy to apps/extension/.env and source it) before `pnpm release`.
AMO_JWT_ISSUER=
AMO_JWT_SECRET=

# Branded ("/j") share links — OFF in the official build, and intentionally so.
# Set FOSSYNC_BRANDED=1 before `pnpm build` to compile in branded share links,
# which point at whatever relay you've configured. Only enable this for a CUSTOM
# build paired with a relay YOU operate: the relay serving /j runs JS in your
# guests' browsers and could read the destination they're opening. The official
# extension refuses to do this. See
# docs/superpowers/specs/2026-06-15-branded-share-links-design.md.
# FOSSYNC_BRANDED=1
